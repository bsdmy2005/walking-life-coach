# Template — safe to commit. Real values go in .env.local (gitignored).
# Copy to .env.local and fill in:  cp .env.example .env.local

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin (password gate for /admin dashboard) ──
# Set this, then sign in at /admin/login.
ADMIN_PASSWORD=change-me

# ── Database (Postgres) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/walking_life_coach

# ── Paystack (payments, ZAR) — https://dashboard.paystack.com ──
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# ── Email notifications (Resend — https://resend.com) ──
# Coach gets an email on every registration + payment. If unset, it just logs.
RESEND_API_KEY=
# Where alerts go. Comma-separate for multiple inboxes.
NOTIFY_EMAIL=you@example.com,assistant@example.com
# Sender — must be a domain verified in Resend for production.
# onboarding@resend.dev works for testing (delivers to your Resend account email).
NOTIFY_FROM=onboarding@resend.dev

# ── Cloudflare R2 storage (optional — image hosting) ──
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
