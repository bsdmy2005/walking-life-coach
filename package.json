{
  "name": "walking-life-coach",
  "version": "0.1.0",
  "private": true,
  "description": "The Walking Life Coach — marketing site, registration, and Paystack payments for Sazi Ngcobo's coaching packages",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
